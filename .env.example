# Copy to .env and fill in your values
# docker compose reads .env automatically

# ── QRadar ────────────────────────────────────────────────────────────────────
QRADAR_HOST=your-qradar-host-or-ip

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HOST=http://elasticsearch:9200
ES_USER=elastic
ES_PASSWORD=changeme

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
