# Copy to .env and fill in your values. docker compose reads .env automatically.
# All ${VAR:?...} variables in docker-compose.yml are MANDATORY — the stack
# will refuse to start without them. Generate strong values, e.g.:
#   openssl rand -base64 32

# ── QRadar ────────────────────────────────────────────────────────────────────
QRADAR_HOST=your-qradar-host-or-ip

# ── API ───────────────────────────────────────────────────────────────────────
# REQUIRED. Used by POST /admin/reload (constant-time comparison).
LOGFILTER_ADMIN_TOKEN=replace-with-openssl-rand-base64-32
# REQUIRED. Used by POST /score and POST /score/batch.
LOGFILTER_API_TOKEN=replace-with-openssl-rand-base64-32
# Optional. If set, /metrics requires this token; leave blank for local Prometheus scraping.
LOGFILTER_METRICS_TOKEN=
# Disabled by default to avoid exposing OpenAPI metadata in deployed services.
LOGFILTER_ENABLE_DOCS=0
CORS_ALLOW_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# REQUIRED. Stack will not start without this.
ES_HOST=http://elasticsearch:9200
ES_USER=elastic
ES_PASSWORD=replace-with-openssl-rand-base64-32

# ── Grafana ───────────────────────────────────────────────────────────────────
# REQUIRED. Default 'admin/admin' has been removed.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-openssl-rand-base64-32

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Collector ─────────────────────────────────────────────────────────────────
# Local-only by default. Set trusted source CIDRs when receiving real syslog.
SYSLOG_ALLOWED_CIDRS=127.0.0.1/32,::1/128
